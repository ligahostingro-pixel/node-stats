# ─── Node Status — Root protection ───────────────────────────
# This file protects sensitive directories if someone accidentally
# sets DocumentRoot to the project root instead of public/.
#
# CORRECT setup:  DocumentRoot /var/www/node-stats/public
# This is a safety net only.

# Block access to config, lib, data, schema
<FilesMatch "^(config\.php|schema_mariadb\.sql|cron\.php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to sensitive directories
RedirectMatch 403 ^/(lib|data|node-agent|\.git)/

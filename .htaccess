# ─── Node Status — LiteSpeed / Apache root .htaccess ─────────
# Routes ALL requests into public/ subfolder automatically.
# Works with LiteSpeed, Apache 2.2+, OpenLiteSpeed.

# Disable directory listing
Options -Indexes

RewriteEngine On

# ── Block sensitive directories ──────────────────────────────
RewriteRule ^(lib|data|node-agent|\.git|bkp)(/|$) - [F,L]

# ── Block root-level sensitive files ─────────────────────────
RewriteRule ^(config\.php|cron\.php|schema_mariadb\.sql|add_node_temp\.php|README\.md|\.gitignore)$ - [F,L]

# ── Forward everything else to public/ ───────────────────────
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L]


# ─── Node Status — LiteSpeed / Apache root .htaccess ─────────
# Disable directory listing
Options -Indexes

RewriteEngine On

# ── Block sensitive directories ──────────────────────────────
RewriteRule ^(lib|data|node-agent|\.git|bkp)(/|$) - [F,L]

# ── Block root-level sensitive files ─────────────────────────
RewriteRule ^(config\.php|cron\.php|schema_mariadb\.sql|add_node_temp\.php|README\.md|\.gitignore)$ - [F,L]

# ── Serve from public/ ───────────────────────────────────────
# Static files: if file exists in public/, serve it directly
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
RewriteRule ^(.+)$ public/$1 [L]

# Directories: rewrite to public/subfolder
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
RewriteRule ^(.+)$ public/$1 [L]

# ── Clean URLs: route extensionless paths to .php in public/ ─
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI}.php -f
RewriteRule ^(.+)$ public/$1.php [L]

# Default: send to public/index.php
RewriteCond %{REQUEST_URI} !^/public/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ public/index.php [L]

